2026-04-14 19:34:14,073 INFO src.llm: Generated SQL:
SELECT u.username, lr.score AS best_score
FROM user u
JOIN participation p ON u.user_id = p.user_id
JOIN competition c ON p.competition_id = c.competition_id
JOIN competition_config cc ON cc.competition_id = c.competition_id
JOIN metric m ON cc.metric_id = m.metric_id
JOIN leaderboard_row lr ON lr.participation_id = p.participation_id
JOIN evaluation e ON e.evaluation_id = lr.best_evaluation_id
WHERE c.title = 'Titanic Dataset'
  AND m.name = 'MSE'
  AND DATE_PART('hour', e.computed_at) BETWEEN 2 AND 3
  AND (
    SELECT COUNT(*) 
    FROM submission s 
    WHERE s.participation_id = p.participation_id
  ) <= 5
ORDER BY lr.score ASC;
