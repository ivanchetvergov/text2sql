- role(role_id SERIAL PK, name VARCHAR(30) UNIQUE -- короткое имя роли (например admin, description TEXT -- текстовое описание назначения роли)
- team_role(team_role_id SERIAL PK, name VARCHAR(15) UNIQUE -- краткое имя роли в команде (например own, description TEXT -- текстовое описание роли в команде)
- dataset(dataset_id BIGINT PK, competition_id BIGINT FK→competition, usage_type VARCHAR {train,test,validation} -- тип использования датасета train (обучен, is_hidden BOOLEAN -- скрытый ли датасет от участников, created_at TIMESTAMPTZ -- дата создания датасета добавления данных)
- competition_status(status_id SERIAL PK, name VARCHAR(15) UNIQUE -- краткое имя статуса соревнования, description TEXT -- описание статуса соревнования)
- team_status(status_id SERIAL PK, name VARCHAR(15) UNIQUE -- краткое имя статуса команды, description TEXT -- описание статуса команды)
- submission(submission_id BIGINT PK, participation_id BIGINT FK→participation, submitted_at TIMESTAMPTZ -- дата и время отправки решения сабмита, status VARCHAR {success,failed,pending} -- статус отправки success (успешно принято)
- task_type(task_type_id BIGINT PK, code VARCHAR {classification,regression,ranking,detection,nlp,clustering} -- код типа задачи например classification , description TEXT -- описание типа задачи машинного обучения, valid_response_format TEXT -- допустимый формат ответа для данного тип)
- participation(participation_id BIGINT PK, user_id BIGINT FK→user, competition_id BIGINT FK→competition, registered_at TIMESTAMPTZ -- дата и время регистрации участника в сор, status VARCHAR {active,withdrawn} -- статус участия active (активный) disqual)
- user(user_id BIGINT PK, username VARCHAR -- имя пользователя, email VARCHAR -- электронная почта пользователя, created_at TIMESTAMPTZ -- дата и время регистрации пользователя на, bio TEXT nullable -- биография пользователя)

## Похожие примеры
Наименьший MSE среди участников соревнования House Price для задачи регрессии
SQL: SELECT MIN(lr.score) AS min_mse FROM competition c JOIN task_type t ON c.task_type_id = t.task_type_id JOIN competition_config cc ON cc.competition_id = c.competition_id JOIN metric m ON m.metric_id = cc.metric_id JOIN participation p ON p.competition_id = c.competition_id JOIN leaderboard_row lr ON lr.participation_id = p.participation_id WHERE t.code = 'regression'
  AND m.name ILIKE '%mse%'
  AND c.title ILIKE '%House Price%';

Метрики для задач классификации с количеством использований в соревнованиях
SQL: SELECT m.name, COUNT(cc.competition_id) AS usage_count FROM metric m JOIN task_type t ON m.task_type_id = t.task_type_id LEFT JOIN competition_config cc ON m.metric_id = cc.metric_id WHERE t.code = 'classification' GROUP BY m.name;
