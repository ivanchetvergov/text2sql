- prize(prize_id BIGINT PK, competition_id BIGINT FK→competition, amount NUMERIC -- сумма приза денежное вознаграждение разм, currency VARCHAR -- валюта приза например USD EUR RUB)
- role(role_id SERIAL PK, name VARCHAR(30) UNIQUE -- короткое имя роли (например admin, description TEXT -- текстовое описание назначения роли)
- user(user_id BIGINT PK, username VARCHAR -- имя пользователя, email VARCHAR -- электронная почта пользователя, created_at TIMESTAMPTZ -- дата и время регистрации пользователя на, bio TEXT nullable -- биография пользователя)
- competition_config(config_id BIGINT PK, competition_id BIGINT FK→competition, metric_id BIGINT FK→metric, aggregation_rule VARCHAR {best,mean,last} -- правило агрегации результатов best (лучш, max_daily_submissions INT -- максимальное количество отправок в день )
- participation(participation_id BIGINT PK, user_id BIGINT FK→user, competition_id BIGINT FK→competition, registered_at TIMESTAMPTZ -- дата и время регистрации участника в сор, status VARCHAR {active,withdrawn} -- статус участия active (активный) disqual)
- dataset_purpose(purpose_id SERIAL PK, name VARCHAR(15) UNIQUE -- краткое имя назначения датасета, description TEXT -- текстовое описание назначения датасета)
- leaderboard_row(participation_id BIGINT PK FK→participation, best_evaluation_id BIGINT FK→evaluation, score FLOAT -- канонический лучший результат участника предпочтительнее evaluation.metric_value для AVG MIN MAX -- лучший score участника итоговый результа, rank INT -- позиция в рейтинге -- место в рейтинге позиция участника в таб)
