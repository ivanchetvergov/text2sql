- team_role(team_role_id SERIAL PK, name VARCHAR(15) UNIQUE -- краткое имя роли в команде (например own, description TEXT -- текстовое описание роли в команде)
- participation_status(status_id SERIAL PK, name VARCHAR(15) UNIQUE -- краткое имя статуса участия, description TEXT -- описание статуса участия)
- task_type(task_type_id BIGINT PK, code VARCHAR {classification,regression,ranking,detection,nlp,clustering} -- код типа задачи например classification , description TEXT -- описание типа задачи машинного обучения, valid_response_format TEXT -- допустимый формат ответа для данного тип)
- dataset(dataset_id BIGINT PK, competition_id BIGINT FK→competition, usage_type VARCHAR {train,test,validation} -- тип использования датасета train (обучен, is_hidden BOOLEAN -- скрытый ли датасет от участников, created_at TIMESTAMPTZ -- дата создания датасета добавления данных)
- metric(metric_id BIGINT PK, task_type_id BIGINT FK→task_type, name VARCHAR -- название метрики например logloss accura, formula TEXT -- математическая формула вычисления метрик, optimization_direction VARCHAR {maximize,minimize} -- направление оптимизации метрики maximize)
- submission(submission_id BIGINT PK, participation_id BIGINT FK→participation, submitted_at TIMESTAMPTZ -- дата и время отправки решения сабмита, status VARCHAR {success,failed,pending} -- статус отправки success (успешно принято)
- evaluation(evaluation_id BIGINT PK, submission_id BIGINT FK→submission, metric_value FLOAT -- числовое значение метрики результат оцен, computed_at TIMESTAMPTZ -- дата и время когда была вычислена оценка)

## Похожие примеры
Пользователи без участия в соревнованиях и без отправок
SQL: SELECT u.user_id, u.username FROM user u WHERE NOT EXISTS (
  SELECT 1 FROM participation p WHERE p.user_id = u.user_id
);

Пользователи участвовавшие в соревнованиях по классификации и имеющие хотя бы одну успешную отправку
SQL: SELECT DISTINCT u.username FROM user u JOIN participation p ON p.user_id = u.user_id JOIN competition c ON c.competition_id = p.competition_id JOIN competition_config cc ON cc.competition_id = c.competition_id JOIN metric m ON m.metric_id = cc.metric_id JOIN task_type t ON t.task_type_id = m.task_type_id JOIN submission s ON s.participation_id = p.participation_id WHERE t.code = 'classification'
  AND s.status = 'success';
============================================================
2026-04-14 19:18:00,815 INFO src.llm: Generated SQL:
SELECT c.competition_id, u.username, lr.score
FROM competition c
JOIN leaderboard_row lr ON lr.participation_id = (
    SELECT p.participation_id
    FROM participation p
    WHERE p.competition_id = c.competition_id
      AND p.status = 'active'
    LIMIT 1
)
JOIN participation p ON p.participation_id = lr.participation_id
JOIN "user" u ON u.user_id = p.user_id
WHERE c.status = 'finished'
  AND lr.rank = 1;
