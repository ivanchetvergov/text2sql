SELECT u.user_id, u.username, pc.participation_count
FROM (
    SELECT user_id, COUNT(*) AS participation_count
    FROM participation
    WHERE team_id IS NOT NULL
    GROUP BY user_id
) pc
JOIN "user" u USING (user_id)
WHERE pc.participation_count IN (
    SELECT participation_count
    FROM (
        SELECT COUNT(*) AS participation_count
        FROM participation
        WHERE team_id IS NOT NULL
        GROUP BY user_id
    ) sub
    GROUP BY participation_count
    HAVING COUNT(*) > 1
)
ORDER BY pc.participation_count, u.user_id;
